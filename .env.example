# ─────────────────────────────────────────────────────────────
# Client-side variables (Vite — exposed to the browser, must be VITE_*)
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"   # Supabase project URL
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"        # Supabase anon/public key (used by src/)
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key" # Supabase publishable/anon key (legacy name)
VITE_SUPABASE_PROJECT_ID="your-project-id"             # Supabase project ref id

# ─────────────────────────────────────────────────────────────
# Server-side secrets (Supabase Edge Functions — never expose to client)
# ─────────────────────────────────────────────────────────────

# Supabase runtime (auto-injected in deployed functions; set locally for dev)
SUPABASE_URL="https://your-project.supabase.co"        # Supabase project URL
SUPABASE_ANON_KEY="your-supabase-anon-key"             # Supabase anon key
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"      # Supabase service role key (full DB access)

# Stripe
STRIPE_SECRET_KEY="sk_test_..."                        # Stripe secret API key
STRIPE_WEBHOOK_SECRET="whsec_..."                      # Stripe webhook signing secret
STRIPE_EDGE_PRO_PRICE_ID="price_..."                   # Stripe price id for the Edge Pro plan

# AI / LLM providers
OPENAI_API_KEY="sk-..."                                # OpenAI API key
OPENAI_TRANSCRIPTION_MODEL="whisper-1"                 # OpenAI transcription model name
GEMINI_API_KEY="your-gemini-api-key"                   # Google Gemini API key
GEMINI_SERVICE_ACCOUNT_KEY="{...}"                     # Gemini service account JSON (for Vertex AI)
PERPLEXITY_API_KEY="pplx-..."                          # Perplexity API key
ARTIFICIALANALYSIS_API_KEY="your-aa-api-key"           # Artificial Analysis API key
ELEVENLABS_API_KEY="your-elevenlabs-api-key"           # ElevenLabs TTS API key

# Search / data enrichment providers
BRAVE_SEARCH_API="your-brave-search-key"               # Brave Search API key
TAVILY_API_KEY="tvly-..."                              # Tavily search API key
JINA_API_KEY="jina_..."                                # Jina AI API key
APOLLO_API_KEY="your-apollo-api-key"                   # Apollo.io API key

# Google OAuth / Sheets
GOOGLE_OAUTH_CLIENT_ID="your-client-id.apps.googleusercontent.com"  # Google OAuth client id
GOOGLE_OAUTH_CLIENT_SECRET="your-google-oauth-client-secret"        # Google OAuth client secret
GOOGLE_OAUTH_CREDENTIALS="{...}"                       # Google OAuth credentials JSON
GOOGLE_SHEETS_SPREADSHEET_ID="your-spreadsheet-id"     # Target Google Sheets spreadsheet id

# Email (Resend)
RESEND_API_KEY="re_..."                                # Resend API key for transactional email
SEND_CONFIRMATION_EMAIL_HOOK_SECRET="your-hook-secret" # Secret for the confirmation-email auth hook

# Encryption keys
MEMORY_ENCRYPTION_KEY="your-32-byte-base64-key"        # Key for encrypting user memory at rest
TOKEN_ENCRYPTION_KEY="your-32-byte-base64-key"         # Key for encrypting cached OAuth tokens

# App URLs
APP_URL="http://localhost:5173"                        # Base app URL used by edge functions
PUBLIC_SITE_URL="http://localhost:5173"                # Public-facing site URL

# Feature flags / tuning (optional — have sensible defaults in code)
MODEL_ROUTING_ENABLED="false"                          # Enable dynamic model routing
BRIEFING_DEDUPE_THRESHOLD="0.85"                       # Similarity threshold for briefing dedupe
BRIEFING_EXCLUDE_THRESHOLD="0.9"                       # Similarity threshold to exclude briefing items
BRIEFING_MIN_RELEVANCE="0.5"                           # Minimum relevance score for briefing items

# Runtime-provided (set automatically by Deno Deploy — do not set manually)
# DENO_DEPLOYMENT_ID
